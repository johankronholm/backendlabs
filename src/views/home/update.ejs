<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Backend Course Labs</title>
</head>
<body>
    <%- include("../partials/header") %>
    <h2>Update task</h2>
       
        <% if (!prev) { %>
    <form action="tasks/update" method="post">
        <label for="id">Id: </label>
        <input type="number" min="1" name="id" value="1">
        <label for="description">Description:</label>
        <input type="text" maxlength="30" name="description" required>
        <label for="completed">Completed?</label>
        <select name="completed" required>
            <option value="true">True</option>
            <option value="false">False</option>
        </select>
        <input type="submit" value="Update task">
    </form>

    <% } else { %> 
        <div>
      <span style="color: <%= status ? "green" : "red" %>;">  <%= status ? "Success!" : "Oops!" %>  </span>
      </div> 
      <% if(status) { %>
        <b>Updated task with id: <%= id %></b>
        <% } else { %>
            Task was not found.<% } %>

                <a href="/update">..Update a new task</a>
        <% } %>

        <%- include("../partials/footer") %>
</body>
</html>